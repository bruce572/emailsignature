    .footer-cell { border-right: 1px solid #444444; padding: 0 10px; }
    .footer-cell:last-child { border-right: none; }
    /* We remove the filter here because your brand assets are already white/colored */
    .brand-logo { max-width: 130px; max-height: 45px; margin: 0 auto; }

    /* Tagline Section */
    .tagline-container { text-align: center; font-size: 13px; font-weight: bold; padding: 15px 0; color: #000; }
    .tagline-line { border-top: 1.5px solid #E6A842; width: 250px; margin: 0 auto 12px auto; }
