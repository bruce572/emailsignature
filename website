    /* Awards Section */
    .awards-strip { background-color: #F7F7F7; padding: 15px 0; border-top: 1px solid #eeeeee; border-bottom: 1px solid #eeeeee; margin: 15px 0; }
    .award-heading { font-size: 18px; font-weight: 900; color: #000000; letter-spacing: 0.5px; }
    .award-subheading { font-size: 10px; font-weight: bold; color: #333333; margin-top: 3px; }

    /* Black Logo Bar */
